# =========================================================
# Panda Trading Bot — Environment Variables
# Copy to .env and fill in values. NEVER commit .env to git.
# =========================================================

# ---------------------------------------------------------
# TRADING MODE (CRITICAL — operator controlled)
# ---------------------------------------------------------
TRADING_MODE=paper                     # paper (default safe) | real
REAL_TRADING_ACKNOWLEDGED=false        # Must be "true" for real trading
OPERATOR_APPROVAL_TOKEN_HASH=          # SHA256 hash of your operator token
OPERATOR_APPROVAL_TOKEN=               # Actual token (never commit)

# ---------------------------------------------------------
# EXCHANGE CREDENTIALS
# ---------------------------------------------------------
BYBIT_API_KEY=
BYBIT_API_SECRET=
BYBIT_TESTNET=true                     # false for real Bybit mainnet

# ---------------------------------------------------------
# DATABASE
# ---------------------------------------------------------
DATABASE_URL=sqlite:///./data/trading.db

# ---------------------------------------------------------
# FREQTRADE SETTINGS
# ---------------------------------------------------------
FREQTRADE_CONFIG=configs/paper.yaml
FREQTRADE_STRATEGY=GridTrendV1
FREQTRADE_USER_DATA_DIR=./user_data

# ---------------------------------------------------------
# DASHBOARD
# ---------------------------------------------------------
DASHBOARD_PORT=8080
DASHBOARD_SECRET_KEY=change-me-before-production
DASHBOARD_USERNAME=admin
DASHBOARD_PASSWORD_HASH=               # bcrypt hash

# ---------------------------------------------------------
# FREQTRADE API (FreqUI)
# ---------------------------------------------------------
FREQTRADE_API_HOST=127.0.0.1
FREQTRADE_API_PORT=8081
FREQTRADE_API_USERNAME=freqtrade
FREQTRADE_API_PASSWORD=change-me

# ---------------------------------------------------------
# METRICS
# ---------------------------------------------------------
PROMETHEUS_PORT=9090
GRAFANA_PORT=3000
GRAFANA_ADMIN_PASSWORD=change-me

# ---------------------------------------------------------
# AUDIT LOG
# ---------------------------------------------------------
AUDIT_LOG_PATH=./data/audit.log
AUDIT_LOG_ROTATION_DAYS=90

# ---------------------------------------------------------
# RISK LIMITS
# ---------------------------------------------------------
MAX_DAILY_LOSS_PCT=2.0
MAX_DRAWDOWN_PCT=10.0
MAX_LEVERAGE=3.0
MAX_OPEN_TRADES=5
MAX_POSITION_SIZE_PCT=10.0
MAX_TOTAL_EXPOSURE_PCT=50.0
CONSECUTIVE_LOSS_PAUSE_COUNT=3
KILL_SWITCH_DRAWDOWN_PCT=15.0
MIN_TRADE_INTERVAL_SECONDS=300
MAX_REJECTION_RATE=0.3

# ---------------------------------------------------------
# NO-ALPHA GATE
# ---------------------------------------------------------
MIN_EXPECTED_NET_EDGE_BPS=5.0
MIN_EXPECTED_GROSS_EDGE_BPS=8.0
MIN_MARKET_QUALITY_SCORE=0.6
MIN_MODEL_QUALITY_SCORE=0.7
MIN_SIGNAL_STRENGTH=0.5
MIN_EDGE_CONFIDENCE=0.6

# ---------------------------------------------------------
# PROMOTION / VALIDATION
# ---------------------------------------------------------
ARTIFACT_MAX_AGE_HOURS=168             # 7 days
BACKTEST_TIMERANGE=20230101-20231231
WALK_FORWARD_WINDOWS=5
SHADOW_MIN_DURATION_HOURS=72

# ---------------------------------------------------------
# ENVIRONMENT
# ---------------------------------------------------------
ENV=development                        # development | staging | production
LOG_LEVEL=INFO
